generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PokemonType {
  Normal
  Fire
  Water
  Electric
  Grass
  Ice
  Fighting
  Poison
  Ground
  Flying
  Psychic
  Bug
  Rock
  Ghost
  Dark
  Dragon
  Steel
  Fairy
}


model Pokemon {
  id           Int     @id
  nameEnglish  String

  type         PokemonType[]

  hp           Int
  attack       Int
  defense      Int
  spAttack     Int
  spDefense    Int
  speed        Int

  species      String
  description  String

  height       String?
  weight       String?
  gender       String?
  ability1     String?
  ability1Hidden Boolean? @default(false)
  ability2     String?
  ability2Hidden Boolean? @default(false)

  sprite       String?
  thumbnail    String?
  hires        String?

  userPokemons UserPokemon[]
}


model User {
  id       Int       @id @default(autoincrement())
  userPokemons UserPokemon[]
}

model UserPokemon {
  userId    Int
  pokemonId Int

  user     User    @relation(fields: [userId], references: [id])
  pokemon  Pokemon @relation(fields: [pokemonId], references: [id])

  @@id([userId, pokemonId]) 
  @@map("UserPokemon")      
}